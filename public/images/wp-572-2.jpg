<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 960 600" width="960" height="600">
<style>
text{font-family:'Microsoft JhengHei','Noto Sans TC',Arial,sans-serif}
.t{font-size:21px;font-weight:bold;fill:#1a1a2e}
.s{font-size:12px;fill:#666}
.pt{font-size:15px;font-weight:bold;fill:white}
.it{font-size:13px;font-weight:bold}
.id{font-size:11px;fill:#555}
</style>
<rect width="960" height="600" fill="#f0f4f8"/>
<text x="480" y="38" class="t" text-anchor="middle">醫療 AI 評估框架轉型</text>
<text x="480" y="58" class="s" text-anchor="middle">從功能導向到治理導向的七個面向比較</text>
<rect x="48" y="70" width="390" height="506" rx="8" fill="white" stroke="#e53935" stroke-width="2"/>
<rect x="48" y="70" width="390" height="46" rx="8" fill="#e53935"/>
<rect x="48" y="98" width="390" height="18" fill="#e53935"/>
<text x="243" y="100" class="pt" text-anchor="middle">舊框架：功能導向評估</text>
<text x="243" y="126" class="s" text-anchor="middle">強調上市前靜態審查</text>
<rect x="70" y="140" width="346" height="76" rx="5" fill="#ffebee" stroke="#ef9a9a" stroke-width="1"/>
<rect x="70" y="140" width="7" height="76" rx="3" fill="#e53935"/>
<text x="96" y="162" class="it" fill="#b71c1c">功能清單核查</text>
<text x="96" y="180" class="id">逐項確認功能是否具備，以通過／不通過為判準</text>
<text x="96" y="198" class="id">缺乏情境適應性，未評估不同使用場域差異</text>
<rect x="70" y="228" width="346" height="76" rx="5" fill="#ffebee" stroke="#ef9a9a" stroke-width="1"/>
<rect x="70" y="228" width="7" height="76" rx="3" fill="#e53935"/>
<text x="96" y="250" class="it" fill="#b71c1c">準確率評估</text>
<text x="96" y="268" class="id">以單一數字概括整體模型表現</text>
<text x="96" y="286" class="id">未考量族群差異，易受測試集偏誤影響</text>
<rect x="70" y="316" width="346" height="76" rx="5" fill="#ffebee" stroke="#ef9a9a" stroke-width="1"/>
<rect x="70" y="316" width="7" height="76" rx="3" fill="#e53935"/>
<text x="96" y="338" class="it" fill="#b71c1c">廠商報告審查</text>
<text x="96" y="356" class="id">仰賴開發商自行提供文件，缺乏獨立查核</text>
<text x="96" y="374" class="id">上市後無系統性監控機制</text>
<rect x="110" y="412" width="266" height="52" rx="6" fill="#ffcdd2" stroke="#e57373" stroke-width="1.5"/>
<text x="243" y="435" font-size="12" text-anchor="middle" fill="#b71c1c" font-weight="bold">評估終止於產品上市核准</text>
<text x="243" y="453" font-size="11" text-anchor="middle" fill="#c62828">一次性靜態審查模式</text>
<line x1="444" y1="308" x2="506" y2="308" stroke="#ff6f00" stroke-width="3"/>
<polygon points="506,300 520,308 506,316" fill="#ff6f00"/>
<text x="483" y="296" font-size="11" text-anchor="middle" fill="#ff6f00" font-weight="bold">轉型</text>
<rect x="522" y="70" width="390" height="506" rx="8" fill="white" stroke="#42a5f5" stroke-width="2"/>
<rect x="522" y="70" width="390" height="46" rx="8" fill="#1565c0"/>
<rect x="522" y="98" width="390" height="18" fill="#1565c0"/>
<text x="717" y="100" class="pt" text-anchor="middle">新框架：治理導向評估</text>
<text x="717" y="126" class="s" text-anchor="middle">強調全生命週期動態監管</text>
<rect x="544" y="140" width="346" height="68" rx="5" fill="#e3f2fd" stroke="#90caf9" stroke-width="1"/>
<rect x="544" y="140" width="7" height="68" rx="3" fill="#1565c0"/>
<text x="569" y="162" class="it" fill="#0d47a1">供應鏈透明度</text>
<text x="569" y="180" class="id">揭露訓練資料來源、標記流程與第三方元件</text>
<text x="569" y="198" class="id">完整追蹤模型血統與資料治理紀錄</text>
<rect x="544" y="218" width="346" height="68" rx="5" fill="#e3f2fd" stroke="#90caf9" stroke-width="1"/>
<rect x="544" y="218" width="7" height="68" rx="3" fill="#1565c0"/>
<text x="569" y="240" class="it" fill="#0d47a1">獨立驗證機制</text>
<text x="569" y="258" class="id">委託第三方機構重現並驗證測試結果</text>
<text x="569" y="276" class="id">涵蓋多族群與不同院所場域的交叉驗證</text>
<rect x="544" y="296" width="346" height="68" rx="5" fill="#e3f2fd" stroke="#90caf9" stroke-width="1"/>
<rect x="544" y="296" width="7" height="68" rx="3" fill="#1565c0"/>
<text x="569" y="318" class="it" fill="#0d47a1">生命週期監控</text>
<text x="569" y="336" class="id">持續追蹤真實世界的臨床應用表現</text>
<text x="569" y="354" class="id">主動偵測模型效能飄移與族群偏差</text>
<rect x="544" y="374" width="346" height="68" rx="5" fill="#e3f2fd" stroke="#90caf9" stroke-width="1"/>
<rect x="544" y="374" width="7" height="68" rx="3" fill="#1565c0"/>
<text x="569" y="396" class="it" fill="#0d47a1">事件通報制度</text>
<text x="569" y="414" class="id">強制通報異常事件與不良使用後果</text>
<text x="569" y="432" class="id">建立跨機構學習回饋與修正機制</text>
<rect x="584" y="454" width="266" height="52" rx="6" fill="#bbdefb" stroke="#42a5f5" stroke-width="1.5"/>
<text x="717" y="477" font-size="12" text-anchor="middle" fill="#0d47a1" font-weight="bold">持續評估於整個使用生命週期</text>
<text x="717" y="495" font-size="11" text-anchor="middle" fill="#1565c0">動態監管取代一次性靜態審查</text>
</svg>