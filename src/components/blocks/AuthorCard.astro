---
import type { Author } from '@/utils/content';
import { authorHasPage, authorAvatar } from '@/utils/content';
import { url } from '@/utils/url';
import ImageWithFallback from '@/components/ui/ImageWithFallback.astro';

interface Props {
  author: Author;
  articleCount?: number;
}
const { author, articleCount } = Astro.props;
const hasPage = authorHasPage(author);
const href = hasPage ? url(`/authors/${author.id}/`) : undefined;
const avatar = authorAvatar(author);

const LEVEL_LABELS: Record<string, string> = {
  contributor: '來稿作者',
  verified: '認證作者',
  columnist: '專欄作者',
  featured: '特約專欄',
  brand: '品牌作者',
};
---
<article class="author-card card-k">
  <ImageWithFallback
    src={avatar}
    alt={author.data.name}
    fallback="og/author.png"
    class="author-avatar"
    width={72}
    height={72}
  />
  <div class="author-info">
    <h3 class="author-name">
      {href ? <a href={href}>{author.data.name}</a> : <span>{author.data.name}</span>}
    </h3>
    {author.data.displayTitle && <p class="author-title">{author.data.displayTitle}</p>}
    {author.data.bioShort && <p class="author-bio">{author.data.bioShort}</p>}
    <div class="author-meta">
      <span class="author-level">{LEVEL_LABELS[author.data.authorLevel]}</span>
      {typeof articleCount === 'number' && <span>{articleCount} 篇文章</span>}
    </div>
    {
      hasPage && (
        <a class="author-link" href={href}>查看專欄 →</a>
      )
    }
  </div>
</article>

<style>
  .author-card {
    display: flex;
    gap: 16px;
    padding: 18px 16px 20px;
    transition: background 0.2s;
  }
  .author-card:hover {
    background: var(--bg-soft);
  }
  :global(.author-avatar) {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--bg-soft);
  }
  .author-info {
    flex: 1;
    min-width: 0;
  }
  .author-name {
    font-size: var(--text-base);
    margin: 0 0 2px;
  }
  .author-name a {
    color: var(--ink);
    text-decoration: none;
  }
  .author-name a:hover {
    color: var(--appi-brand);
  }
  .author-title {
    margin: 0 0 8px;
    font-size: var(--text-xs);
    color: var(--appi-brand);
    font-weight: 600;
    font-family: var(--font-sans);
  }
  .author-bio {
    margin: 0 0 10px;
    font-size: var(--text-xs);
    color: var(--ink-3);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .author-meta {
    display: flex;
    gap: 12px;
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
  }
  .author-level {
    color: var(--ink-2);
    background: var(--bg-soft);
    padding: 1px 8px;
    border-radius: 4px;
  }
  .author-link {
    display: inline-block;
    margin-top: 12px;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--appi-brand);
    font-family: var(--font-sans);
  }
</style>
