---
import type { Column } from '@/utils/content';
import { url, asset } from '@/utils/url';
import { getCategory } from '@/config/categories';
import ImageWithFallback from '@/components/ui/ImageWithFallback.astro';

interface Props {
  column: Column;
  ownerName?: string;
  articleCount?: number;
}
const { column, ownerName, articleCount } = Astro.props;
const href = url(`/columns/${column.id}/`);
const cover = column.data.coverImage
  ? asset(column.data.coverImage)
  : asset(`og/${column.data.category ?? 'columns'}.png`);
const cat = getCategory(column.data.category);
---
<article class="column-card card-k">
  <a class="column-cover" href={href} aria-hidden="true" tabindex="-1">
    <ImageWithFallback src={cover} alt={column.data.title} fallback="og/columns.png" />
  </a>
  <div class="column-body">
    {cat && <span class="column-cat">{cat.name}</span>}
    <h3 class="column-title"><a href={href}>{column.data.title}</a></h3>
    <p class="column-desc">{column.data.description}</p>
    <div class="column-meta">
      {ownerName && <span class="column-owner">{ownerName}</span>}
      {typeof articleCount === 'number' && <span>{articleCount} 篇</span>}
    </div>
  </div>
</article>

<style>
  .column-card {
    display: flex;
    flex-direction: column;
    padding-top: 12px;
    transition: box-shadow 0.2s;
  }
  .column-card:hover {
    box-shadow: var(--shadow-sm);
  }
  .column-cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius-sm);
    background: var(--bg-soft);
  }
  .column-cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .column-body {
    padding: 16px 18px 20px;
  }
  .column-cat {
    font-size: var(--text-xs);
    font-weight: 600;
    font-family: var(--font-sans);
    color: var(--ink-3);
  }
  .column-title {
    margin: 6px 0 8px;
    font-size: var(--text-base);
  }
  .column-title a {
    color: var(--ink);
    text-decoration: none;
  }
  .column-title a:hover {
    color: var(--appi-brand);
  }
  .column-desc {
    margin: 0 0 12px;
    font-size: var(--text-xs);
    color: var(--ink-3);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .column-meta {
    display: flex;
    gap: 12px;
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
  }
  .column-owner {
    color: var(--ink-2);
    font-weight: 600;
  }
</style>
