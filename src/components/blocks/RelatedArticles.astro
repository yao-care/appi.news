---
import type { Article } from '@/utils/content';
import ArticleCard from '@/components/blocks/ArticleCard.astro';

interface Props {
  articles: Article[];
  authorNames?: Map<string, string>;
  title?: string;
}
const { articles, authorNames, title = '相關文章' } = Astro.props;
---
{
  articles.length > 0 && (
    <section class="related section">
      <div class="section-head"><h2>{title}</h2></div>
      <div class="card-grid card-grid--3">
        {articles.map((a) => (
          <ArticleCard
            article={a}
            variant="medium"
            authorName={authorNames?.get(a.data.author)}
          />
        ))}
      </div>
    </section>
  )
}

<style>
  /* 延伸閱讀固定 3 則：全站無寬度上限下，這裡仍維持一個寬度上限置中，
     避免 3 張卡在寬螢幕被 auto-fill 拉散、靠左留大片空白。 */
  .related {
    max-width: 1180px;
    margin-inline: auto;
  }
</style>
