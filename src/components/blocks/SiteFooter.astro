---
import { SITE } from '@/config/site';
import { FOOTER_COLUMNS } from '@/config/nav';
import { url } from '@/utils/url';
const year = SITE.org.foundingYear;
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="brand-mark">APPI</span>
      <p class="footer-tag">{SITE.tagline}</p>
      <p class="footer-tag-en">{SITE.taglineEn}</p>
      <p class="footer-desc">
        結合 AI 輔助寫作、專家審稿與媒體刊登的專業觀點平台。
      </p>
    </div>

    <div class="footer-cols">
      {
        FOOTER_COLUMNS.map((col) => (
          <div class="footer-col">
            <h3>{col.title}</h3>
            <ul>
              {col.links.map((l) => (
                <li><a href={url(l.href)}>{l.label}</a></li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>Copyright © {year} APPI News. All rights reserved.</p>
      <p class="footer-note">
        APPI News 不提供個人化醫療、法律或投資建議。商業合作內容均依規範揭露。
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--appi-brand);
    color: #d7e0ec;
    margin-top: 80px;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.2fr 3fr;
    gap: 48px;
    padding-block: 52px;
  }
  .brand-mark {
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: 0.04em;
    font-size: 1.4rem;
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    display: inline-block;
  }
  .footer-tag {
    margin: 14px 0 2px;
    font-weight: 600;
    color: #fff;
  }
  .footer-tag-en {
    margin: 0;
    font-size: 0.8rem;
    color: #9fb2cc;
    letter-spacing: 0.03em;
  }
  .footer-desc {
    margin-top: 14px;
    font-size: 0.88rem;
    line-height: 1.7;
    color: #b8c6dc;
    max-width: 280px;
  }
  .footer-cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }
  .footer-col h3 {
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    margin: 0 0 14px;
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-col li {
    margin-bottom: 9px;
  }
  .footer-col a {
    color: #c3d0e2;
    font-size: 0.88rem;
    text-decoration: none;
  }
  .footer-col a:hover {
    color: #fff;
    text-decoration: underline;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-block: 20px;
    font-size: 0.8rem;
    color: #9fb2cc;
  }
  .footer-bottom p {
    margin: 4px 0;
  }
  .footer-note {
    color: #8499b8;
  }

  @media (max-width: 860px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .footer-cols {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
