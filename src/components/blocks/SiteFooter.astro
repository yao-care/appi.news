---
import { SITE } from '@/config/site';
import { FOOTER_COLUMNS } from '@/config/nav';
import { CATEGORY_MAP } from '@/config/categories';
import { getActiveCategorySlugs } from '@/utils/content';
import { url } from '@/utils/url';
const year = SITE.org.foundingYear;

// 隱藏沒有已發佈文章的分類連結（與主導覽一致）
const active = await getActiveCategorySlugs();
const footerColumns = FOOTER_COLUMNS.map((col) => ({
  ...col,
  links: col.links.filter((l) => {
    const m = l.href.match(/^\/([^/]+)\/$/);
    const slug = m?.[1];
    if (!slug || !CATEGORY_MAP[slug]) return true;
    return active.has(slug);
  }),
})).filter((col) => col.links.length > 0);
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <div class="footer-masthead">
        <span class="footer-brand-name">APPI News</span>
      </div>
      <p class="footer-tag">{SITE.tagline}</p>
      <p class="footer-tag-en">{SITE.taglineEn}</p>
      <p class="footer-desc">
        提供跨領域專業觀點與深度報導，聚焦健康、科技、財經、國際、運動與生活等重要議題。
      </p>
    </div>

    <div class="footer-cols">
      {
        footerColumns.map((col) => (
          <div class="footer-col">
            <h3>{col.title}</h3>
            <ul>
              {col.links.map((l) => (
                <li><a href={url(l.href)}>{l.label}</a></li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>Copyright © {year} APPI News. All rights reserved.</p>
      <p class="footer-note">
        APPI News 不提供個人化醫療、法律或投資建議。商業合作內容均依規範揭露。
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--appi-brand);
    color: var(--on-brand);
    margin-top: 80px;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.2fr 3fr;
    gap: 48px;
    padding-block: 52px;
  }
  .footer-masthead {
    display: flex;
    align-items: center;
  }
  .footer-brand-name {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: 0.01em;
    color: var(--white);
  }
  .footer-tag {
    margin: 14px 0 2px;
    font-weight: 600;
    color: var(--white);
    font-size: var(--text-sm);
  }
  .footer-tag-en {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--on-brand-dim);
    letter-spacing: 0.03em;
  }
  .footer-desc {
    margin-top: 14px;
    font-size: var(--text-xs);
    line-height: 1.7;
    color: var(--on-brand);
    max-width: 280px;
  }
  .footer-cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }
  .footer-col h3 {
    color: var(--white);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    margin: 0 0 14px;
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-col li {
    margin-bottom: 9px;
  }
  .footer-col a {
    color: var(--on-brand);
    font-size: var(--text-xs);
    text-decoration: none;
  }
  .footer-col a:hover {
    color: var(--white);
    text-decoration: underline;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-block: 20px;
    font-size: var(--text-xs);
    color: var(--on-brand-dim);
  }
  .footer-bottom p {
    margin: 4px 0;
  }
  .footer-note {
    color: var(--on-brand-dim);
  }

  @media (max-width: 860px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .footer-cols {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
