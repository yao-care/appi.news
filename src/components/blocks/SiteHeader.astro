---
import { SITE } from '@/config/site';
import { MAIN_NAV } from '@/config/nav';
import { CATEGORY_MAP } from '@/config/categories';
import { getActiveCategorySlugs } from '@/utils/content';
import { url } from '@/utils/url';

// 隱藏沒有已發佈文章的分類（避免導覽連到空頁面）
const active = await getActiveCategorySlugs();
const navItems = MAIN_NAV.filter((item) => {
  const m = item.href.match(/^\/([^/]+)\/$/);
  const slug = m?.[1];
  if (!slug || !CATEGORY_MAP[slug]) return true; // 非分類連結（作者群等）一律保留
  return active.has(slug);
});

const navUrl = (p: string) => url(p);
const current = Astro.url.pathname;
function isActive(href: string): boolean {
  const target = url(href);
  if (target === url('/')) return current === target;
  return current.startsWith(target);
}
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={navUrl('/')} aria-label="APPI News">
      <span class="brand-mark" aria-hidden="true">A</span>
      <span class="brand-name">APPI<span class="brand-name-accent">News</span></span>
    </a>

    <nav class="main-nav" aria-label="主選單">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a href={navUrl(item.href)} class={isActive(item.href) ? 'active' : ''}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      <a class="search-link" href={navUrl('/search/')} aria-label="搜尋">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
      </a>
      <button class="nav-toggle" aria-label="開啟選單" aria-expanded="false" id="navToggle">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
  </div>

  <!-- 行動版選單 -->
  <nav class="mobile-nav" id="mobileNav" aria-label="行動版選單" hidden>
    <ul>
      {
        navItems.map((item) => (
          <li><a href={navUrl(item.href)}>{item.label}</a></li>
        ))
      }
      <li><a href={navUrl('/search/')}>搜尋</a></li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('navToggle');
  const menu = document.getElementById('mobileNav');
  toggle?.addEventListener('click', () => {
    const open = menu?.hasAttribute('hidden');
    if (open) {
      menu?.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    } else {
      menu?.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: saturate(180%) blur(8px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 28px;
    height: 64px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    flex-shrink: 0;
  }
  /* 品牌標記：金底圓角方塊內白色 A，做為 wordmark 前的識別符號 */
  .brand-mark {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--appi-brand) 0%, var(--appi-brand-light) 100%);
    color: var(--white);
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 1.05rem;
    line-height: 1;
    letter-spacing: 0;
    box-shadow: inset 0 0 0 1.5px rgba(255, 255, 255, 0.12);
  }
  .brand-mark::after {
    /* 右下金色點，增加設計細節 */
    content: '';
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--appi-accent);
    transform: translate(11px, 10px);
    border: 1.5px solid var(--white);
  }
  .brand-name {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    color: var(--appi-brand);
  }
  .brand-name-accent {
    color: var(--appi-accent);
    margin-left: 0.18em;
    font-weight: 700;
  }
  .main-nav {
    flex: 1;
    align-self: stretch; /* 讓 nav 撐滿 header-inner 的 64px 高度 */
  }
  .main-nav ul {
    display: flex;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
    height: 100%;
    align-items: stretch; /* li 撐滿高度，連結才能跟著撐滿 */
    flex-wrap: wrap;
  }
  .main-nav a {
    display: flex;
    align-items: center; /* 文字垂直置中 */
    height: 100%; /* 觸發區與 header 同高，方便點擊 */
    padding: 0 10px;
    color: var(--ink-2);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
  }
  .main-nav a:hover {
    background: var(--bg-soft);
    color: var(--ink);
  }
  .main-nav a.active {
    color: var(--appi-brand);
    font-weight: 700;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .search-link {
    color: var(--ink-2);
    display: inline-flex;
  }
  .search-link:hover {
    color: var(--appi-brand);
  }
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--ink);
    cursor: pointer;
    padding: 4px;
  }
  .mobile-nav {
    border-top: 1px solid var(--line);
    background: var(--white);
  }
  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 8px 0;
  }
  .mobile-nav a {
    display: block;
    padding: 12px 20px;
    color: var(--ink-2);
    font-weight: 500;
    border-bottom: 1px solid var(--line-2);
    text-decoration: none;
  }
  .mobile-nav a:hover {
    color: var(--appi-brand);
  }

  @media (max-width: 1000px) {
    .main-nav {
      display: none;
    }
    .nav-toggle {
      display: inline-flex;
    }
    .header-inner {
      justify-content: space-between;
    }
  }
  @media (min-width: 1001px) {
    .mobile-nav {
      display: none;
    }
  }
  @media (max-width: 480px) {
    .header-inner {
      gap: 14px;
    }
  }
</style>
