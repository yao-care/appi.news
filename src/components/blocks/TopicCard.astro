---
import type { Topic } from '@/utils/content';
import { url, asset } from '@/utils/url';
import ImageWithFallback from '@/components/ui/ImageWithFallback.astro';

interface Props {
  topic: Topic;
  articleCount?: number;
}
const { topic, articleCount } = Astro.props;
const href = url(`/topics/${topic.id}/`);
const cover = topic.data.coverImage
  ? asset(topic.data.coverImage)
  : asset(`og/${topic.data.category ?? 'focus'}.png`);
---
<a class="topic-card" href={href}>
  <ImageWithFallback src={cover} alt={topic.data.title} fallback="og/focus.png" class="topic-bg" />
  <span class="topic-overlay"></span>
  <span class="topic-content">
    <span class="topic-label">專題</span>
    <span class="topic-title">{topic.data.title}</span>
    {typeof articleCount === 'number' && <span class="topic-count">{articleCount} 篇文章</span>}
  </span>
</a>

<style>
  .topic-card {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
  }
  :global(.topic-bg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .topic-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15, 25, 45, 0.85), rgba(15, 25, 45, 0.15));
  }
  .topic-content {
    position: absolute;
    inset: auto 0 0 0;
    padding: 18px 20px;
    color: #fff;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .topic-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #cdd9ee;
    font-family: var(--font-sans);
  }
  .topic-title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.35;
  }
  .topic-count {
    font-size: 0.8rem;
    color: #cdd9ee;
    font-family: var(--font-sans);
  }
</style>
