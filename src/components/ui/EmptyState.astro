---
interface Props {
  title?: string;
  message?: string;
}
const {
  title = '內容即將上線',
  message = '這個區塊的文章正在準備中，請稍後再回來看看。',
} = Astro.props;
---
<div class="empty-state">
  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
  <h3>{title}</h3>
  <p>{message}</p>
</div>

<style>
  .empty-state {
    text-align: center;
    padding: 56px 20px;
    color: var(--ink-3);
  }
  .empty-state svg {
    color: var(--line);
    margin-bottom: 12px;
  }
  .empty-state h3 {
    margin: 0 0 6px;
    color: var(--ink-2);
    font-size: var(--text-base);
  }
  .empty-state p {
    margin: 0;
    font-size: var(--text-sm);
  }
</style>
