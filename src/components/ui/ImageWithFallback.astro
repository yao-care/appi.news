---
import { asset } from '@/utils/url';

interface Props {
  src: string;
  alt: string;
  /** 載入失敗時的 fallback（相對 BASE 路徑或絕對網址） */
  fallback?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  /** LCP 首屏主圖設 'high'，讓瀏覽器優先抓（Core Web Vitals 建議；其餘維持 auto） */
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
}
const {
  src,
  alt,
  fallback = 'og/default.png',
  class: className,
  loading = 'lazy',
  fetchpriority,
  width,
  height,
} = Astro.props;

const fallbackSrc = /^https?:\/\//.test(fallback) ? fallback : asset(fallback);
---
<img
  src={src}
  alt={alt}
  class={className}
  loading={loading}
  fetchpriority={fetchpriority}
  width={width}
  height={height}
  data-fallback={fallbackSrc}
  onerror="if(this.src!==this.dataset.fallback){this.src=this.dataset.fallback;}"
/>
