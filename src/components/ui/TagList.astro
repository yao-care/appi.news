---
import { url } from '@/utils/url';
import { slugify } from '@/utils/content';

interface Props {
  tags: string[];
  title?: string;
  /** 純文字模式：標籤不連到 /tags/ 頁（排程草稿預覽用，避免連到尚未產出的 tag 頁）。 */
  plain?: boolean;
}
const { tags, title, plain = false } = Astro.props;
---
{
  tags.length > 0 && (
    <div class="tag-list">
      {title && <span class="tag-list-title">{title}</span>}
      <ul>
        {tags.map((t) => (
          <li>
            {plain ? <span>#{t}</span> : <a href={url(`/tags/${slugify(t)}/`)}>#{t}</a>}
          </li>
        ))}
      </ul>
    </div>
  )
}

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  .tag-list-title {
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-weight: 600;
    margin-right: 4px;
  }
  .tag-list ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tag-list a,
  .tag-list ul span {
    display: inline-block;
    font-size: var(--text-xs);
    color: var(--ink-2);
    background: var(--bg-soft);
    padding: 4px 11px;
    border-radius: 20px;
    text-decoration: none;
    font-family: var(--font-sans);
  }
  .tag-list a:hover {
    background: var(--bg-tint);
    color: var(--appi-brand);
  }
</style>
