---
import '@/styles/global.css';
import { SITE } from '@/config/site';
import SEOHead from '@/components/seo/SEOHead.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import SiteHeader from '@/components/blocks/SiteHeader.astro';
import SiteFooter from '@/components/blocks/SiteFooter.astro';
import Analytics from '@/components/seo/Analytics.astro';
import { orgLd, websiteLd } from '@/utils/jsonld';
import { CATEGORY_SLUGS, getCategoryName } from '@/config/categories';

interface Props {
  title: string;
  description?: string;
  path: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  authorName?: string;
  authorPath?: string;
  keywords?: string[];
  /** 額外的 structured data（文章頁、作者頁等） */
  jsonld?: Record<string, any> | Record<string, any>[];
  /** 額外的 RSS feed（如分類 feed）供 <head> 自動探索 */
  rssHref?: string;
  rssTitle?: string;
  /** GA content_group（分區塊觀測用）。文章頁 URL 無分類，須明確傳 category；
   *  其餘頁不傳、由 path 自動推導（首頁=home、/tech/=tech、/authors/=authors…）。 */
  contentGroup?: string;
}

const {
  title,
  description,
  path,
  ogImage,
  ogType,
  noindex,
  publishedTime,
  modifiedTime,
  authorName,
  authorPath,
  keywords,
  jsonld,
  rssHref,
  rssTitle,
  contentGroup,
} = Astro.props;

const baseLd = [websiteLd(Astro.site), orgLd(Astro.site)];

// content_group：先取原始 key（明確傳入的 category slug，或由 path 首段推導），
// 再映射成中文分類名給 GA（分類走 getCategoryName，其餘用固定對照）。
const seg = (path || '/').split(/[?#]/)[0].replace(/^\/+/, '').split('/')[0];
const cgKey =
  contentGroup ||
  (!seg
    ? 'home'
    : CATEGORY_SLUGS.includes(seg) || ['authors', 'topics', 'tags', 'articles'].includes(seg)
      ? seg
      : 'other');
const CG_LABELS: Record<string, string> = { home: '首頁', authors: '作者群', topics: '專題', tags: '標籤', articles: '文章', other: '其他' };
const resolvedContentGroup = CATEGORY_SLUGS.includes(cgKey) ? getCategoryName(cgKey) : (CG_LABELS[cgKey] ?? '其他');
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <SEOHead
      title={title}
      description={description}
      path={path}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      authorName={authorName}
      authorPath={authorPath}
      keywords={keywords}
      rssHref={rssHref}
      rssTitle={rssTitle}
    />
    <JsonLd data={baseLd} />
    {jsonld && <JsonLd data={jsonld} />}
    <Analytics contentGroup={resolvedContentGroup} />
  </head>
  <body>
    <a class="skip-link" href="#main">跳到主要內容</a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--appi-brand);
        color: var(--white);
        padding: 10px 16px;
        z-index: 100;
      }
      .skip-link:focus {
        left: 0;
      }
    </style>
  </body>
</html>
