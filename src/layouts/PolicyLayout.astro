---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@/components/ui/Breadcrumbs.astro';

interface Props {
  title: string;
  description?: string;
  path: string;
  updated?: string;
  lead?: string;
}
const { title, description, path, updated, lead } = Astro.props;
---
<BaseLayout title={title} description={description ?? lead} path={path}>
  <div class="container policy-wrap">
    <div class="policy-shell">
      <Breadcrumbs items={[{ name: title }]} />
      <header class="policy-head">
        <h1>{title}</h1>
        {lead && <p class="policy-lead">{lead}</p>}
        {updated && <p class="policy-updated">最後更新：{updated}</p>}
      </header>
      <div class="prose article-body policy-body">
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .policy-wrap {
    padding-block: 32px 24px;
  }
  /* 單欄閱讀版心：麵包屑、頁首、正文共用同一條閱讀寬度並置中，
     不受全站 .container 滿版（--maxw: none）影響。 */
  .policy-shell {
    max-width: var(--maxw-prose);
    margin-inline: auto;
  }
  .policy-head {
    margin-block: 16px 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }
  .policy-head h1 {
    font-size: var(--text-xl);
    margin: 0 0 10px;
  }
  .policy-lead {
    font-size: var(--text-sm);
    color: var(--ink-2);
    line-height: 1.7;
    margin: 0;
  }
  .policy-updated {
    margin: 12px 0 0;
    font-size: var(--text-xs);
    color: var(--ink-3);
  }
  .policy-body {
    /* 閱讀寬度已由 .policy-shell 統一掌管，正文只需填滿外層。 */
    max-width: none;
  }
</style>
