---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategoryChannel from '@/components/blocks/CategoryChannel.astro';
import { CATEGORIES } from '@/config/categories';
import {
  getPublishedArticles,
  getAuthorMap,
  byCategory,
} from '@/utils/content';
import { url } from '@/utils/url';

const PAGE_SIZE = 18;

export async function getStaticPaths() {
  // 'columns' 由 /columns/ 專屬頁處理，這裡排除避免路由衝突
  return CATEGORIES.filter((c) => c.slug !== 'columns').map((c) => ({
    params: { category: c.slug },
    props: { category: c },
  }));
}

const { category } = Astro.props;
const all = await getPublishedArticles();
const authorMap = await getAuthorMap();
const authorNames = new Map(
  [...authorMap.entries()].map(([id, a]) => [id, a.data.name]),
);

const inCat = byCategory(all, category.slug);
const totalPages = Math.max(1, Math.ceil(inCat.length / PAGE_SIZE));
const pageArticles = inCat.slice(0, PAGE_SIZE);
---
<BaseLayout
  title={`${category.name}｜${category.nameEn}`}
  description={category.description}
  path={`/${category.slug}/`}
  ogImage={`og/${category.slug}.png`}
>
  {category.slug === 'sports' && (
    <section class="sports-submit-cta">
      <div class="container">
        <span>🏅 學校、隊伍或主辦單位嗎？</span>
        <a href={url('/sports/submit/')}>提供你們的學生賽事資訊 →</a>
      </div>
    </section>
  )}
  <CategoryChannel
    category={category}
    pageArticles={pageArticles}
    allInCategory={inCat}
    authorNames={authorNames}
    currentPage={1}
    totalPages={totalPages}
    showHero={true}
  />
</BaseLayout>

<style>
  .sports-submit-cta { background: var(--color-surface-alt, #f4f6f8); border-radius: 10px; margin: 1rem auto 0; }
  .sports-submit-cta .container { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; align-items: center; padding: 0.8rem 1rem; }
  .sports-submit-cta span { font-weight: 600; }
  .sports-submit-cta a { font-weight: 700; color: var(--color-accent, #1a6); text-decoration: none; }
  .sports-submit-cta a:hover { text-decoration: underline; }
</style>
