---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '@/utils/url';
import { articleSlug } from '@/utils/content';
import AdminLogin from '@/components/editor/AdminLogin.svelte';
import NewArticle from '@/components/editor/NewArticle.svelte';

const articleEntries = await getCollection('articles', ({ data }) => !data.draft);
const quickLinks = articleEntries.slice(0, 5).map((e) => ({
  title: e.data.title,
  href: url(`/articles/${articleSlug(e)}/`),
}));
// 編輯器作者下拉用：id + 名稱 + GitHub 登入（對應預設作者）
const authorOptions = (await getCollection('authors')).map((a) => ({
  id: a.id,
  name: a.data.name,
  githubLogin: a.data.githubLogin ?? '',
}));
---
<BaseLayout title="管理登入" path="/admin/" noindex={true}>
  <div class="et-admin">
    <h1>管理登入</h1>
    <AdminLogin client:only="svelte" />

    <section class="et-help">
      <h2>怎麼編輯文章？</h2>
      <ol>
        <li>在<strong>目前這個分頁</strong>用 GitHub 登入（登入狀態只在這個分頁有效，請不要另開新分頁）。</li>
        <li>點下方任一篇文章前往（會在同一個分頁開啟）。</li>
        <li>文章頁<strong>右下角</strong>會浮出「編輯」鈕，點它就能修改內容並存檔。</li>
      </ol>
      <ul class="et-links">
        {quickLinks.map((l) => <li><a href={l.href}>{l.title}</a></li>)}
      </ul>
    </section>

    <NewArticle client:only="svelte" authors={authorOptions} />
  </div>
</BaseLayout>

<style>
  .et-admin {
    max-width: 48rem;
    margin-inline: auto;
    padding: var(--space-page-y) var(--space-page-x);
    color: var(--color-ink);
  }
  .et-help {
    margin-top: clamp(1.5rem, 1rem + 2vw, 2.5rem);
    padding: clamp(1rem, 0.75rem + 1vw, 1.5rem);
    background: color-mix(in oklch, var(--color-paper) 55%, white);
    border: 1px solid var(--color-fog);
    border-radius: var(--radius-card);
  }
  .et-help h2 {
    font-size: var(--text-h3);
    margin-bottom: 0.5rem;
  }
  .et-help ol {
    margin: 0 0 1rem;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .et-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .et-links a {
    color: var(--color-teal);
    font-weight: 600;
  }
</style>
