---
import { render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/ui/Breadcrumbs.astro';
import CategoryTag from '@/components/ui/CategoryTag.astro';
import TagList from '@/components/ui/TagList.astro';
import DisclosureBox from '@/components/blocks/DisclosureBox.astro';
import DisclaimerBox from '@/components/blocks/DisclaimerBox.astro';
import ReferenceList from '@/components/blocks/ReferenceList.astro';
import AuthorBioBox from '@/components/blocks/AuthorBioBox.astro';
import ShareButtons from '@/components/blocks/ShareButtons.astro';
import RelatedArticles from '@/components/blocks/RelatedArticles.astro';
import ImageWithFallback from '@/components/ui/ImageWithFallback.astro';
import EditButton from '@/components/editor/EditButton.svelte';
import {
  getPublishedArticles,
  getScheduledPreviewArticles,
  getAuthorMap,
  articleSlug,
  coverImageFor,
  coverAltFor,
  readingTime,
  relatedArticles,
  adjacent,
  authorHasPage,
  extractFaq,
  getTopics,
  authorAvatar,
} from '@/utils/content';
import { getCategory, getSubcategoryName } from '@/config/categories';
import { formatDate, isoDate } from '@/utils/date';
import { absoluteUrl, url } from '@/utils/url';
import { articleLd, breadcrumbLd, faqLd } from '@/utils/jsonld';

export async function getStaticPaths() {
  const published = await getPublishedArticles();
  // 排程草稿也產頁（noindex、不進列表），供站內預覽＋編輯；到 publishDate 後 cron 重建自動轉正。
  const previews = await getScheduledPreviewArticles();
  return [
    ...published.map((article) => ({
      params: { slug: articleSlug(article) },
      props: { article, preview: false },
    })),
    ...previews.map((article) => ({
      params: { slug: articleSlug(article) },
      props: { article, preview: true },
    })),
  ];
}

const { article, preview = false } = Astro.props;
const all = await getPublishedArticles();
const authorMap = await getAuthorMap();

const cat = getCategory(article.data.category);
const subName = getSubcategoryName(article.data.category, article.data.subcategory);
const author = authorMap.get(article.data.author);
const authorName = author?.data.name ?? 'APPI 編輯部';
const rt = readingTime(article);
const cover = coverImageFor(article);
const path = `/articles/${articleSlug(article)}/`;

const related = relatedArticles(all, article, 3);
const authorNames = new Map(
  [...authorMap.entries()].map(([id, a]) => [id, a.data.name]),
);
// 編輯器作者下拉用
const authorOptions = [...authorMap.values()].map((a) => ({
  id: a.id,
  name: a.data.name,
  githubLogin: a.data.githubLogin ?? '',
}));
const { newer, older } = adjacent(all, article);

const { Content } = await render(article);

// 只有 updatedDate 晚於 publishDate 才視為有效更新日；早於或等於一律忽略，
// 避免顯示無意義的「更新於」與輸出 dateModified < datePublished 的無效結構化資料。
const validUpdatedDate =
  article.data.updatedDate &&
  article.data.updatedDate.getTime() > article.data.publishDate.getTime()
    ? article.data.updatedDate
    : undefined;

const topicTitle = new Map((await getTopics()).map((t) => [t.id, t.data.title]));
const aboutNames = article.data.topics
  .map((s) => topicTitle.get(s))
  .filter((x): x is string => Boolean(x));
const authorImageAbs = author
  ? new URL(authorAvatar(author), Astro.site).toString()
  : undefined;

const isMedicalOrNews =
  article.data.category === 'health' || article.data.category === 'focus';

// structured data
const crumbItems = [
  { name: cat?.name ?? '文章', path: `/${article.data.category}/` },
  { name: article.data.title, path },
];
const ld = [
  articleLd(Astro.site, {
    headline: article.data.title,
    description: article.data.description,
    path,
    image: new URL(cover, Astro.site).toString(),
    datePublished: isoDate(article.data.publishDate),
    dateModified: isoDate(validUpdatedDate ?? article.data.publishDate),
    author: {
      name: authorName,
      path: authorHasPage(author) ? `/authors/${author!.id}/` : undefined,
      image: authorImageAbs,
      jobTitle: author?.data.displayTitle,
      sameAs: author?.data.socialLinks.map((s) => s.url),
      knowsAbout: author?.data.specialties,
      isOrganization: author?.data.isOrganization,
    },
    section: cat?.name,
    isNews: isMedicalOrNews,
    keywords: article.data.tags,
    about: aboutNames,
    citations: article.data.references.map((r) => ({
      title: r.title,
      url: r.url,
      publisher: r.publisher,
    })),
  }),
  breadcrumbLd(Astro.site, [{ name: '首頁', path: '/' }, ...crumbItems]),
];

// FAQPage 結構化資料（若文章含「常見問題」區段）
const faq = extractFaq(article.body ?? '');
if (faq.length > 0) ld.push(faqLd(faq));

const shareUrl = absoluteUrl(path, Astro.site);
const ogImg = article.data.coverImage ?? `og/${article.data.category}.png`;
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  path={path}
  ogType="article"
  ogImage={ogImg}
  publishedTime={isoDate(article.data.publishDate)}
  modifiedTime={isoDate(validUpdatedDate ?? article.data.publishDate)}
  authorName={authorName}
  authorPath={authorHasPage(author) ? `/authors/${author!.id}/` : undefined}
  keywords={article.data.tags}
  jsonld={ld}
  noindex={preview}
>
  <article class="article">
    {
      preview && (
        <div class="container">
          <p class="article-preview-banner">
            排程草稿預覽（未公開）· 預定 {formatDate(article.data.publishDate)} 發佈。
            登入 <a href={url('/admin/')}>/admin</a> 後右下角會浮出「編輯」鈕可直接修改。
          </p>
        </div>
      )
    }
    <div class="container article-head-wrap">
      <Breadcrumbs items={crumbItems} />

      <div class="article-head">
        <div class="article-cat">
          <CategoryTag
            category={article.data.category}
            subcategory={article.data.subcategory}
          />
        </div>
        <h1>{article.data.title}</h1>
        <p class="article-desc">{article.data.description}</p>

        <div class="article-byline">
          {
            authorHasPage(author) ? (
              <a class="byline-author" href={url(`/authors/${author!.id}/`)}>{authorName}</a>
            ) : (
              <span class="byline-author">{authorName}</span>
            )
          }
          {author?.data.displayTitle && <span class="byline-title">{author.data.displayTitle}</span>}
          <span class="byline-sep">·</span>
          <time datetime={isoDate(article.data.publishDate)}>
            {formatDate(article.data.publishDate)}
          </time>
          {
            validUpdatedDate && (
              <span class="byline-updated">（更新於 {formatDate(validUpdatedDate)}）</span>
            )
          }
          <span class="byline-sep">·</span>
          <span>{rt} 分鐘閱讀</span>
        </div>
      </div>
    </div>

    <div class="container article-cover-wrap">
      <ImageWithFallback
        src={cover}
        alt={coverAltFor(article)}
        fallback={`og/${article.data.category}.png`}
        class="article-cover"
        loading="eager"
      />
      {article.data.coverImageCredit && (
        <p class="article-cover-credit">攝影：{article.data.coverImageCredit}</p>
      )}
    </div>

    <div class="container article-main">
      <div class="article-content">
        <DisclosureBox sourceType={article.data.sourceType} custom={article.data.disclosure} />

        {
          article.data.highlights.length > 0 && (
            <aside class="highlights">
              <h2>本文重點</h2>
              <ul>
                {article.data.highlights.map((h) => <li>{h}</li>)}
              </ul>
            </aside>
          )
        }

        <div class="article-body">
          <Content />
        </div>

        {
          article.data.expertNote && (
            <aside class="expert-note">
              <h2>主編判讀</h2>
              <p>{article.data.expertNote}</p>
            </aside>
          )
        }

        {
          article.data.risksAndLimits.length > 0 && (
            <aside class="risks">
              <h2>風險與限制</h2>
              <ul>
                {article.data.risksAndLimits.map((r) => <li>{r}</li>)}
              </ul>
            </aside>
          )
        }

        <ReferenceList references={article.data.references} />

        <DisclaimerBox type={article.data.disclaimerType} />

        <TagList tags={article.data.tags} title="標籤" plain={preview} />

        <ShareButtons url={shareUrl} title={article.data.title} />

        {author && <AuthorBioBox author={author} />}

        <nav class="prevnext" aria-label="上一篇下一篇">
          {
            older && (
              <a class="prevnext-item" href={url(`/articles/${articleSlug(older)}/`)}>
                <span class="pn-label">← 較舊文章</span>
                <span class="pn-title">{older.data.title}</span>
              </a>
            )
          }
          {
            newer && (
              <a class="prevnext-item prevnext-next" href={url(`/articles/${articleSlug(newer)}/`)}>
                <span class="pn-label">較新文章 →</span>
                <span class="pn-title">{newer.data.title}</span>
              </a>
            )
          }
        </nav>
      </div>
    </div>

    <div class="container">
      <RelatedArticles articles={related} authorNames={authorNames} title="延伸閱讀" />
    </div>
  </article>
  <EditButton
    client:idle
    repoPath={article.filePath}
    collection="articles"
    slug={articleSlug(article)}
    authors={authorOptions}
  />
</BaseLayout>

<style>
  .article-preview-banner {
    max-width: var(--maxw-prose);
    margin: 18px auto 0;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-coral);
    border-radius: var(--radius-card);
    background: color-mix(in oklch, var(--color-coral) 12%, white);
    color: var(--color-ink);
    font-family: var(--font-ui);
    font-size: var(--text-meta);
    line-height: 1.5;
  }
  .article-preview-banner a {
    color: var(--color-coral);
    font-weight: 600;
  }
  .article-head-wrap {
    padding-top: 28px;
  }
  .article-head {
    max-width: var(--maxw-prose);
    margin: 18px auto 0;
  }
  .article-cat {
    margin-bottom: 14px;
  }
  .article-head h1 {
    font-size: var(--text-2xl);
    line-height: 1.3;
    margin: 0 0 16px;
  }
  .article-desc {
    font-size: var(--text-base);
    color: var(--ink-2);
    line-height: 1.7;
    margin: 0 0 20px;
  }
  .article-byline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }
  .byline-author {
    font-weight: 700;
    color: var(--ink);
  }
  a.byline-author:hover {
    color: var(--appi-brand);
  }
  .byline-title {
    color: var(--appi-brand);
    font-weight: 500;
  }
  .byline-sep {
    color: var(--line);
  }
  .article-cover-wrap {
    margin-top: 28px;
  }
  :global(.article-cover) {
    width: 100%;
    max-width: var(--maxw-prose);
    margin-inline: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius);
  }
  .article-cover-credit {
    max-width: var(--maxw-prose);
    margin: 6px auto 0;
    font-family: var(--font-ui);
    font-size: var(--text-badge);
    color: var(--color-ink-2, #888);
    text-align: right;
  }
  .article-main {
    margin-top: 8px;
  }
  .article-content {
    max-width: var(--maxw-prose);
    margin-inline: auto;
    padding-top: 8px;
  }
  .highlights {
    background: var(--bg-tint);
    border-radius: var(--radius);
    padding: 20px 24px;
    margin-block: 28px;
  }
  .highlights h2 {
    font-size: var(--text-base);
    margin: 0 0 10px;
    color: var(--ink);
  }
  .highlights ul {
    margin: 0;
    padding-left: 1.2em;
  }
  .highlights li {
    margin-bottom: 6px;
    color: var(--ink-2);
  }
  .expert-note,
  .risks {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 20px 24px;
    margin-block: 28px;
  }
  .expert-note {
    border-left: 4px solid var(--appi-brand);
    background: var(--bg-soft);
  }
  .risks {
    border-left: 4px solid var(--appi-accent);
    background: var(--appi-accent-soft);
  }
  .expert-note h2,
  .risks h2 {
    font-size: var(--text-base);
    margin: 0 0 10px;
  }
  .risks ul {
    margin: 0;
    padding-left: 1.2em;
  }
  .prevnext {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 36px;
  }
  .prevnext-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px 18px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    text-decoration: none;
  }
  .prevnext-item:hover {
    border-color: var(--appi-brand);
  }
  .prevnext-next {
    text-align: right;
  }
  .pn-label {
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
  }
  .pn-title {
    font-size: var(--text-sm);
    color: var(--ink);
    font-weight: 600;
    line-height: 1.4;
  }

  @media (max-width: 600px) {
    .article-head h1 {
      font-size: var(--text-xl);
    }
    .prevnext {
      grid-template-columns: 1fr;
    }
    .prevnext-next {
      text-align: left;
    }
  }
</style>
