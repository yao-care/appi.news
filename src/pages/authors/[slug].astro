---
import { render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import Breadcrumbs from '@/components/ui/Breadcrumbs.astro';
import ImageWithFallback from '@/components/ui/ImageWithFallback.astro';
import EmptyState from '@/components/ui/EmptyState.astro';
import {
  getAuthors,
  getPublishedArticles,
  getAuthorMap,
  byAuthor,
  authorHasPage,
  authorHasColumnPage,
  authorAvatar,
} from '@/utils/content';
import { getColumns } from '@/utils/content';
import { url, asset } from '@/utils/url';
import { personLd, breadcrumbLd } from '@/utils/jsonld';

export async function getStaticPaths() {
  const authors = await getAuthors();
  return authors
    .filter((a) => authorHasPage(a))
    .map((author) => ({ params: { slug: author.id }, props: { author } }));
}

const { author } = Astro.props;
const all = await getPublishedArticles();
const authorMap = await getAuthorMap();
const authorNames = new Map(
  [...authorMap.entries()].map(([id, a]) => [id, a.data.name]),
);
const articles = byAuthor(all, author.id);
const path = `/authors/${author.id}/`;
const avatar = authorAvatar(author);
// 作者頁內文左欄用完整人像（正方形大圖）；缺 portrait 時退回 avatar，再退回 og fallback
const heroImage = author.data.portrait ? asset(author.data.portrait) : avatar;

const allColumns = await getColumns();
const myColumns = allColumns.filter(
  (c) => c.data.ownerAuthor === author.id || c.data.coAuthors.includes(author.id),
);

const { Content } = await render(author);

const LEVEL_LABELS: Record<string, string> = {
  contributor: '來稿作者',
  verified: '認證作者',
  columnist: '專欄作者',
  featured: '特約專欄',
  brand: '品牌作者',
};

const hasContact =
  Boolean(author.data.website) ||
  author.data.socialLinks.length > 0 ||
  Boolean(author.data.emailPublic);

const ld = [
  personLd(Astro.site, {
    name: author.data.name,
    path,
    jobTitle: author.data.displayTitle,
    description: author.data.bioShort,
    image: new URL(avatar, Astro.site).toString(),
    sameAs: author.data.socialLinks.map((s) => s.url),
  }),
  breadcrumbLd(Astro.site, [
    { name: '首頁', path: '/' },
    { name: '作者群', path: '/authors/' },
    { name: author.data.name, path },
  ]),
];
---
<BaseLayout
  title={author.data.name}
  description={author.data.bioShort || `${author.data.name} 在 APPI News 的文章與專欄。`}
  path={path}
  ogImage={author.data.avatar ?? 'og/author.png'}
  jsonld={ld}
>
  <div class="container author-page">
    <Breadcrumbs items={[{ name: '作者群', path: '/authors/' }, { name: author.data.name }]} />

    <div class="author-hero">
      <div class="author-intro">
        <ImageWithFallback src={heroImage} alt={author.data.name} fallback="og/author.png" class="author-intro-img" width={600} height={600} />
        <span class="author-intro-level">{LEVEL_LABELS[author.data.authorLevel]}</span>
        <h1 class="author-intro-name">{author.data.name}</h1>
        {author.data.displayTitle && <p class="author-intro-title">{author.data.displayTitle}</p>}
        {author.data.bioShort && <p class="author-intro-lead">{author.data.bioShort}</p>}

        {
          author.data.credentials.length > 0 && (
            <div class="author-intro-block">
              <h2>現任與經歷</h2>
              <ul class="author-creds">
                {author.data.credentials.map((c) => <li>{c}</li>)}
              </ul>
            </div>
          )
        }

        {
          hasContact && (
            <div class="author-intro-block">
              <h2>聯絡</h2>
              <div class="author-links">
                {author.data.website && (
                  <a href={author.data.website} rel="me noopener" target="_blank">官方網站</a>
                )}
                {author.data.socialLinks.map((s) => (
                  <a href={s.url} rel="me noopener" target="_blank">{s.label}</a>
                ))}
                {author.data.emailPublic && (
                  <a href={`mailto:${author.data.emailPublic}`}>{author.data.emailPublic}</a>
                )}
              </div>
            </div>
          )
        }

        {
          author.data.joinedDate && (
            <p class="author-joined">加入於 {author.data.joinedDate.getFullYear()} 年</p>
          )
        }
      </div>

      <div class="author-detail">
        {
          author.data.specialties.length > 0 && (
            <div class="author-detail-block">
              <h2>專長領域</h2>
              <ul class="author-specialties">
                {author.data.specialties.map((s) => <li>{s}</li>)}
              </ul>
            </div>
          )
        }

        <div class="author-bio prose article-body">
          <Content />
        </div>
      </div>
    </div>

    {
      myColumns.length > 0 && authorHasColumnPage(author) && (
        <section class="section">
          <div class="section-head"><h2>專欄</h2></div>
          <ul class="author-columns">
            {myColumns.map((c) => (
              <li>
                <a href={url(`/columns/${c.id}/`)}>{c.data.title}</a>
                <span>{c.data.description}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="section">
      <div class="section-head"><h2>文章（{articles.length}）</h2></div>
      {
        articles.length > 0 ? (
          <div class="card-grid">
            {articles.map((a) => <ArticleCard article={a} variant="medium" authorName={authorNames.get(a.data.author)} />)}
          </div>
        ) : (
          <EmptyState title="尚無文章" message="這位作者的文章即將上線。" />
        )
      }
    </section>
  </div>
</BaseLayout>

<style>
  .author-page {
    padding-top: 28px;
  }

  /* ---------- Hero：左右各半，重點落在左欄 ---------- */
  .author-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
    margin: 24px 0 8px;
  }

  /* ---------- 左欄：介紹（重點、字較大） ---------- */
  .author-intro {
    min-width: 0;
  }
  :global(.author-intro-img) {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    border-radius: var(--radius);
    background: var(--bg-soft);
    box-shadow: var(--shadow-sm);
  }
  .author-intro-level {
    display: inline-block;
    margin-top: 20px;
    font-size: var(--text-xs);
    color: var(--appi-brand);
    background: var(--bg-tint);
    padding: 3px 12px;
    border-radius: 20px;
    font-family: var(--font-sans);
    font-weight: 600;
  }
  .author-intro-name {
    font-size: var(--text-2xl);
    line-height: 1.2;
    margin: 14px 0 6px;
  }
  .author-intro-title {
    margin: 0;
    color: var(--appi-brand);
    font-weight: 600;
    font-size: var(--text-base);
    font-family: var(--font-sans);
    line-height: 1.4;
  }
  .author-intro-lead {
    margin: 16px 0 0;
    font-size: var(--text-base);
    line-height: 1.85;
    color: var(--ink-2);
  }
  .author-intro-block {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--line-2);
  }
  .author-intro-block h2 {
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: 0.04em;
    margin: 0 0 14px;
  }
  .author-creds {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }
  .author-creds li {
    font-size: var(--text-sm);
    color: var(--ink);
    font-weight: 600;
    font-family: var(--font-sans);
    line-height: 1.4;
    padding-left: 12px;
    border-left: 3px solid var(--appi-accent);
  }
  .author-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: var(--text-sm);
    font-family: var(--font-sans);
  }
  .author-links a {
    color: var(--appi-brand);
    font-weight: 600;
    word-break: break-all;
  }
  .author-joined {
    margin: 20px 0 0;
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
  }

  /* ---------- 右欄：專長領域 + 詳細介紹 ---------- */
  .author-detail {
    min-width: 0;
  }
  .author-detail-block {
    margin-bottom: 32px;
  }
  .author-detail-block h2 {
    font-size: var(--text-xl);
    margin: 0 0 16px;
  }
  .author-specialties {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }
  .author-specialties li {
    font-size: var(--text-base);
    color: var(--ink);
    font-family: var(--font-sans);
    line-height: 1.5;
    padding: 10px 16px;
    background: var(--bg-soft);
    border-left: 3px solid var(--appi-brand);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .author-bio {
    max-width: none;
  }
  .author-columns {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 14px;
  }
  .author-columns li {
    border: none;
    border-top: 3px solid var(--appi-accent);
    border-radius: 0;
    padding: 14px 18px 16px;
  }
  .author-columns a {
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--ink);
  }
  .author-columns span {
    display: block;
    color: var(--ink-3);
    font-size: var(--text-xs);
    margin-top: 4px;
  }

  @media (max-width: 860px) {
    .author-hero {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    :global(.author-intro-img) {
      max-width: 340px;
    }
    .author-intro-name {
      font-size: var(--text-xl);
    }
  }
</style>
