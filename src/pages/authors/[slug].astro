---
import { render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import Breadcrumbs from '@/components/ui/Breadcrumbs.astro';
import ImageWithFallback from '@/components/ui/ImageWithFallback.astro';
import EmptyState from '@/components/ui/EmptyState.astro';
import {
  getAuthors,
  getPublishedArticles,
  getAuthorMap,
  byAuthor,
  authorHasPage,
  authorHasColumnPage,
  authorAvatar,
} from '@/utils/content';
import { getColumns } from '@/utils/content';
import { url } from '@/utils/url';
import { personLd, breadcrumbLd } from '@/utils/jsonld';

export async function getStaticPaths() {
  const authors = await getAuthors();
  return authors
    .filter((a) => authorHasPage(a))
    .map((author) => ({ params: { slug: author.id }, props: { author } }));
}

const { author } = Astro.props;
const all = await getPublishedArticles();
const authorMap = await getAuthorMap();
const authorNames = new Map(
  [...authorMap.entries()].map(([id, a]) => [id, a.data.name]),
);
const articles = byAuthor(all, author.id);
const path = `/authors/${author.id}/`;
const avatar = authorAvatar(author);

const allColumns = await getColumns();
const myColumns = allColumns.filter(
  (c) => c.data.ownerAuthor === author.id || c.data.coAuthors.includes(author.id),
);

const { Content } = await render(author);

const LEVEL_LABELS: Record<string, string> = {
  contributor: '來稿作者',
  verified: '認證作者',
  columnist: '專欄作者',
  featured: '特約專欄',
  brand: '品牌作者',
};

const hasContact =
  Boolean(author.data.website) ||
  author.data.socialLinks.length > 0 ||
  Boolean(author.data.emailPublic);

const ld = [
  personLd(Astro.site, {
    name: author.data.name,
    path,
    jobTitle: author.data.displayTitle,
    description: author.data.bioShort,
    image: new URL(avatar, Astro.site).toString(),
    sameAs: author.data.socialLinks.map((s) => s.url),
  }),
  breadcrumbLd(Astro.site, [
    { name: '首頁', path: '/' },
    { name: '作者群', path: '/authors/' },
    { name: author.data.name, path },
  ]),
];
---
<BaseLayout
  title={author.data.name}
  description={author.data.bioShort || `${author.data.name} 在 APPI News 的文章與專欄。`}
  path={path}
  ogImage={author.data.avatar ?? 'og/author.png'}
  jsonld={ld}
>
  <div class="container author-page">
    <Breadcrumbs items={[{ name: '作者群', path: '/authors/' }, { name: author.data.name }]} />

    <div class="author-layout">
      <aside class="author-aside">
        <div class="author-card">
          <ImageWithFallback src={avatar} alt={author.data.name} fallback="og/author.png" class="author-aside-avatar" width={120} height={120} />
          <span class="author-aside-level">{LEVEL_LABELS[author.data.authorLevel]}</span>
          <h1 class="author-aside-name">{author.data.name}</h1>
          {author.data.displayTitle && <p class="author-aside-title">{author.data.displayTitle}</p>}

          {
            author.data.credentials.length > 0 && (
              <div class="author-aside-block">
                <h2>現任與經歷</h2>
                <ul class="author-aside-creds">
                  {author.data.credentials.map((c) => <li>{c}</li>)}
                </ul>
              </div>
            )
          }

          {
            hasContact && (
              <div class="author-aside-block">
                <h2>聯絡</h2>
                <div class="author-aside-links">
                  {author.data.website && (
                    <a href={author.data.website} rel="me noopener" target="_blank">官方網站</a>
                  )}
                  {author.data.socialLinks.map((s) => (
                    <a href={s.url} rel="me noopener" target="_blank">{s.label}</a>
                  ))}
                  {author.data.emailPublic && (
                    <a href={`mailto:${author.data.emailPublic}`}>{author.data.emailPublic}</a>
                  )}
                </div>
              </div>
            )
          }

          {
            author.data.joinedDate && (
              <p class="author-aside-joined">加入於 {author.data.joinedDate.getFullYear()} 年</p>
            )
          }
        </div>
      </aside>

      <div class="author-main">
        <div class="author-bio prose article-body">
          <Content />
        </div>

        {
          myColumns.length > 0 && authorHasColumnPage(author) && (
            <section class="section">
              <div class="section-head"><h2>專欄</h2></div>
              <ul class="author-columns">
                {myColumns.map((c) => (
                  <li>
                    <a href={url(`/columns/${c.id}/`)}>{c.data.title}</a>
                    <span>{c.data.description}</span>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <section class="section">
          <div class="section-head"><h2>文章（{articles.length}）</h2></div>
          {
            articles.length > 0 ? (
              <div class="card-grid">
                {articles.map((a) => <ArticleCard article={a} variant="medium" authorName={authorNames.get(a.data.author)} />)}
              </div>
            ) : (
              <EmptyState title="尚無文章" message="這位作者的文章即將上線。" />
            )
          }
        </section>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .author-page {
    padding-top: 28px;
  }

  .author-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 40px;
    align-items: start;
    margin-top: 24px;
  }

  /* ---------- 左欄：個人檔案卡 ---------- */
  .author-aside {
    position: sticky;
    top: 80px;
  }
  .author-card {
    background: var(--bg-soft);
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    padding: 24px;
  }
  :global(.author-aside-avatar) {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--bg-soft);
    border: 3px solid #fff;
    box-shadow: var(--shadow-sm);
  }
  .author-aside-level {
    display: inline-block;
    margin-top: 16px;
    font-size: var(--text-xs);
    color: var(--appi-brand);
    background: var(--bg-tint);
    padding: 2px 10px;
    border-radius: 20px;
    font-family: var(--font-sans);
    font-weight: 600;
  }
  .author-aside-name {
    font-size: var(--text-lg);
    line-height: 1.3;
    margin: 12px 0 4px;
  }
  .author-aside-title {
    margin: 0;
    color: var(--appi-brand);
    font-weight: 600;
    font-size: var(--text-sm);
    font-family: var(--font-sans);
  }
  .author-aside-block {
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--line-2);
  }
  .author-aside-block h2 {
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: 0.04em;
    margin: 0 0 12px;
  }
  .author-aside-creds {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }
  .author-aside-creds li {
    font-size: var(--text-sm);
    color: var(--ink);
    font-weight: 600;
    font-family: var(--font-sans);
    line-height: 1.4;
    padding-left: 12px;
    border-left: 3px solid var(--appi-accent);
  }
  .author-aside-links {
    display: flex;
    flex-direction: column;
    gap: 9px;
    font-size: var(--text-xs);
    font-family: var(--font-sans);
  }
  .author-aside-links a {
    color: var(--appi-brand);
    font-weight: 600;
    word-break: break-all;
  }
  .author-aside-joined {
    margin: 18px 0 0;
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
  }

  /* ---------- 右欄：主內容 ---------- */
  .author-main {
    min-width: 0;
  }
  .author-bio {
    max-width: var(--maxw-prose);
  }
  .author-columns {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 14px;
  }
  .author-columns li {
    border: none;
    border-top: 3px solid var(--appi-accent);
    border-radius: 0;
    padding: 14px 18px 16px;
  }
  .author-columns a {
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--ink);
  }
  .author-columns span {
    display: block;
    color: var(--ink-3);
    font-size: var(--text-xs);
    margin-top: 4px;
  }

  @media (max-width: 860px) {
    .author-layout {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .author-aside {
      position: static;
    }
  }
</style>
