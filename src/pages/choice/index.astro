---
import { url } from '@/utils/url';

const PAGES = [
  { id: 'index', label: '首頁' },
  { id: 'articles', label: '文章內頁' },
  { id: 'authors', label: '作者群' },
  { id: 'join', label: '成為作者' },
];
const VARIANTS = [
  { id: 'a', label: '關鍵評論網 The News Lens', desc: '青綠＋橘・多分類密集平台・5 欄小卡＋排行' },
  { id: 'b', label: '報導者 The Reporter', desc: '黑白＋深teal・襯線、大留白、深度閱讀感' },
  { id: 'c', label: '泛科學 PanSci', desc: 'cyan＋琥珀・知識標籤導向・4 欄卡片' },
  { id: 'd', label: '食力 foodNEXT', desc: '深色 header＋番茄紅・密集＋側欄熱門' },
  { id: 'e', label: 'VERSE', desc: '純黑白・極簡編輯、大圖、大留白、雜誌感' },
  { id: 'f', label: 'INSIDE', desc: '乾淨白＋藍・快節奏科技、整齊 4 欄卡片' },
  { id: 'g', label: 'APPI 推薦混合', desc: '藏青＋金・襯線、結構化、信任質感（TNL架構＋報導者信任＋知識轉譯＋VERSE質感）' },
];
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>APPI 風格預覽總覽</title>
    <style>
      body { margin: 0; font-family: 'Noto Sans TC', system-ui, sans-serif; color: #1e2030; background: #f5f6f8; line-height: 1.6; }
      .wrap { max-width: 1000px; margin: 0 auto; padding: 40px 24px 80px; }
      h1 { font-size: 30px; margin: 0 0 6px; }
      .sub { color: #5e6070; margin: 0 0 32px; }
      .v { background: #fff; border: 1px solid #d5d6da; border-radius: 12px; padding: 22px 24px; margin-bottom: 18px; }
      .v-head { display: flex; align-items: baseline; gap: 12px; margin-bottom: 4px; }
      .v-head .code { font-weight: 800; color: #1f6feb; font-size: 20px; }
      .v-head h2 { margin: 0; font-size: 20px; }
      .v .desc { color: #5e6070; font-size: 15px; margin: 0 0 14px; }
      .links { display: flex; flex-wrap: wrap; gap: 10px; }
      .links a { text-decoration: none; color: #1e2030; background: #f0f4f9; border: 1px solid #d5d6da; padding: 8px 16px; border-radius: 8px; font-size: 15px; }
      .links a:hover { background: #1f6feb; color: #fff; border-color: #1f6feb; }
      .note { background: #fff8e6; border: 1px solid #f0d98a; border-radius: 8px; padding: 14px 18px; font-size: 14px; color: #6b5800; margin-bottom: 28px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <h1>APPI News｜風格預覽</h1>
      <p class="sub">4 種頁型 × 5 種風格，共 20 個 mockup。點開後可用頂部切換列快速比較。</p>
      <div class="note">
        這些是<strong>選色 / 選版用的 mockup</strong>，非正式頁面（已設 noindex）。
        你可以對我說「我要 A 的顏色 + C 的版型」這類組合，我再據此調整正式站。
      </div>

      {VARIANTS.map((v) => (
        <div class="v">
          <div class="v-head"><span class="code">{v.id.toUpperCase()}</span><h2>{v.label}</h2></div>
          <p class="desc">{v.desc}</p>
          <div class="links">
            {PAGES.map((p) => (
              <a href={url(`/choice/${p.id}/${v.id}/`)}>{p.label} →</a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </body>
</html>
