---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import HeroNetwork from '@/components/blocks/HeroNetwork.astro';
import ImageWithFallback from '@/components/ui/ImageWithFallback.astro';
import CategoryTag from '@/components/ui/CategoryTag.astro';
import { SITE } from '@/config/site';
import {
  getPublishedArticles,
  getAuthorMap,
  featuredArticles,
  makeDeduper,
  articleSlug,
  coverImageFor,
  coverAltFor,
} from '@/utils/content';
import { url } from '@/utils/url';
import { formatDate } from '@/utils/date';

const all = await getPublishedArticles();
const authorMap = await getAuthorMap();
const authorNames = new Map(
  [...authorMap.entries()].map(([id, a]) => [id, a.data.name]),
);
const authorName = (id: string) => authorNames.get(id) ?? 'APPI 編輯部';

const dedupe = makeDeduper();

// Hero：hero=true 優先，否則最新 featured，否則最新
const hero =
  all.find((a) => a.data.hero) ??
  all.find((a) => a.data.featured) ??
  all[0];
if (hero) dedupe.take([hero], 1);

// 精選右側：5 篇含小縮圖的清單（補滿垂直空間 + 易辨識）
const secondary = dedupe.take([...featuredArticles(all), ...all], 5);

// 最新文章：單一等高大圖網格（補滿空間）
const latest = dedupe.take(all, 12, false);

const heroCover = hero ? coverImageFor(hero) : '';
const heroHref = hero ? url(`/articles/${articleSlug(hero)}/`) : '#';
---

<BaseLayout title="首頁" path="/" ogImage="og/home.png">
  <!-- 網站介紹 Hero 區：承接從 header 移下來的中文定位 + 站台介紹 -->
  <section class="intro">
    <HeroNetwork />
    <div class="container intro-inner">
      <div class="intro-text">
        <span class="intro-eyebrow">{SITE.taglineEn}</span>
        <h1 class="intro-title">{SITE.tagline}</h1>
        <p class="intro-desc">
          聚集各領域專業作者，以新聞、評論、專欄、專題、專訪與深度分析，協助讀者理解健康、科技、財經、國際、運動與生活中的重要議題。
        </p>
        <div class="intro-cta">
          <a class="btn btn--primary" href={url('/articles/')}>探索所有文章</a>
          <a class="btn btn--ghost" href="#editors-pick">查看編輯精選</a>
        </div>
      </div>
    </div>
  </section>

  {
    hero && (
      <div class="container">
        <section class="section feature-section" id="editors-pick">
          <div class="section-head">
            <h2>編輯精選</h2>
            <a class="more-link" href={url('/articles/')}>所有文章 →</a>
          </div>

          <div class="feature">
            <article class="feature-main">
              <a class="feature-media" href={heroHref} tabindex="-1" aria-hidden="true">
                <ImageWithFallback
                  src={heroCover}
                  alt={coverAltFor(hero)}
                  fallback={`og/${hero.data.category}.png`}
                  loading="eager"
                  class="feature-img"
                />
              </a>
              <div class="feature-text">
                <CategoryTag category={hero.data.category} subcategory={hero.data.subcategory} />
                <h3 class="feature-title"><a href={heroHref}>{hero.data.title}</a></h3>
                <p class="feature-excerpt">{hero.data.excerpt ?? hero.data.description}</p>
                <span class="feature-meta">
                  {authorName(hero.data.author)} · {formatDate(hero.data.publishDate)}
                </span>
              </div>
            </article>

            <div class="feature-side">
              {
                secondary.map((a) => (
                  <a class="side-item" href={url(`/articles/${articleSlug(a)}/`)}>
                    <span class="side-thumb">
                      <ImageWithFallback
                        src={coverImageFor(a)}
                        alt={coverAltFor(a)}
                        fallback={`og/${a.data.category}.png`}
                        class="side-img"
                      />
                    </span>
                    <span class="side-body">
                      <span class="side-title">{a.data.title}</span>
                      <span class="side-meta">
                        {authorName(a.data.author)} · {formatDate(a.data.publishDate)}
                      </span>
                    </span>
                  </a>
                ))
              }
            </div>
          </div>
        </section>
      </div>
    )
  }

  <div class="container">
    <section class="section home-latest">
      <div class="section-head">
        <h2>最新文章</h2>
        <a class="more-link" href={url('/articles/')}>所有文章 →</a>
      </div>
      <div class="card-grid">
        {
          latest.map((a) => (
            <ArticleCard
              article={a}
              variant="medium"
              showExcerpt={false}
              authorName={authorNames.get(a.data.author)}
            />
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ---------- 網站介紹 Hero 區 ---------- */
  .intro {
    position: relative;
    background:
      radial-gradient(120% 150% at 88% 0%, var(--bg-tint) 0%, transparent 58%),
      linear-gradient(180deg, var(--bg-soft) 0%, var(--white) 100%);
    border-bottom: 1px solid var(--line-2);
  }
  .intro-inner {
    position: relative;
    z-index: 1;
    padding-top: 64px;
    padding-bottom: 64px;
  }
  /* 拿掉右側 Editorial Index 後改為置中報頭：左右網絡背景對稱，避免單側留白 */
  .intro-text {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }
  .intro-eyebrow {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--appi-accent);
    font-weight: 600;
  }
  .intro-title {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    line-height: 1.2;
    margin: 12px 0 0;
    color: var(--ink);
  }
  .intro-desc {
    margin: 16px auto 28px;
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--ink-2);
    max-width: 52ch;
  }
  .intro-cta {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ---------- 編輯精選 ---------- */
  .feature {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 40px;
    align-items: stretch; /* 兩欄等高：由內容較高的右側清單決定列高 */
  }
  /* 左欄改 flex 直排：標題/摘要佔自然高度，主圖填滿剩餘高度，
     使「圖+標題」整體高度＝右側 5 篇清單高度（全站滿版下不再讓 16:9 主圖自己撐高）。 */
  .feature-main {
    display: flex;
    flex-direction: column;
  }
  .feature-media {
    display: block;
    overflow: hidden;
    border-radius: var(--radius);
    flex: 1 1 auto;
    min-height: 200px; /* 極端比例下的保底高度，避免主圖被壓到過扁 */
    background: var(--bg-soft);
    box-shadow: var(--shadow-md);
  }
  /* postbuild 會把 feature 圖包進 <picture>（大螢幕換高解圖）；picture 預設 inline，
     需 block 撐滿 .feature-media 外框，圖才不會塌高（CLS 仍由外框 aspect-ratio 控制）。 */
  .feature-media :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }
  :global(.feature-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .feature-media:hover :global(.feature-img) {
    transform: scale(1.03);
  }
  .feature-text {
    padding-top: 18px;
  }
  .feature-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    line-height: 1.3;
    margin: 12px 0;
  }
  .feature-title a {
    color: var(--ink);
    text-decoration: none;
  }
  .feature-title a:hover {
    color: var(--appi-brand);
  }
  .feature-excerpt {
    color: var(--ink-2);
    font-size: var(--text-base);
    line-height: 1.7;
    margin: 0 0 14px;
  }
  .feature-meta {
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
  }

  /* 精選右側：含小縮圖的文章清單（金色強調左線） */
  .feature-side {
    display: flex;
    flex-direction: column;
    border-left: 3px solid var(--appi-accent);
    padding-left: 24px;
  }
  .side-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 16px 0;
    text-decoration: none;
    border-bottom: 1px solid var(--line-2);
  }
  .side-item:first-child {
    padding-top: 0;
  }
  .side-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .side-thumb {
    flex: 0 0 88px;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--bg-soft);
  }
  :global(.side-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .side-item:hover :global(.side-img) {
    transform: scale(1.05);
  }
  .side-body {
    flex: 1;
    min-width: 0;
  }
  .side-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.25rem; /* 20px — 恢復至先前列表字級 */
    line-height: 1.45;
    color: var(--ink);
  }
  .side-item:hover .side-title {
    color: var(--appi-brand);
  }
  .side-meta {
    display: block;
    margin-top: 6px;
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
  }

  /* ---------- 最新文章：恢復至先前較大的卡片標題字級 ---------- */
  .home-latest :global(.acard--medium .acard-title) {
    font-size: 1.375rem; /* 22px */
  }

  @media (max-width: 900px) {
    /* 平板：報頭收窄留白，讓影像豐富的「編輯精選」更早進入視野 */
    .intro-inner {
      padding-top: 44px;
      padding-bottom: 44px;
    }
    .feature {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    /* 單欄堆疊時沒有右側可對齊，主圖恢復 16:9 正常框 */
    .feature-main {
      display: block;
    }
    .feature-media {
      aspect-ratio: 16 / 9;
      min-height: 0;
    }
    .feature-side {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--line);
      padding-top: 8px;
    }
  }

  @media (max-width: 520px) {
    /* 手機：進一步壓縮報頭高度，首屏底部就能看到「編輯精選」的封面圖 */
    .intro-inner {
      padding-top: 32px;
      padding-bottom: 28px;
    }
    .intro-desc {
      margin-bottom: 24px;
    }
    .side-thumb {
      flex-basis: 72px;
    }
    .side-title {
      font-size: 1.125rem;
    }
  }
</style>
