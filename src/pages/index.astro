---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import HeroNetwork from '@/components/blocks/HeroNetwork.astro';
import ImageWithFallback from '@/components/ui/ImageWithFallback.astro';
import CategoryTag from '@/components/ui/CategoryTag.astro';
import { SITE } from '@/config/site';
import {
  getPublishedArticles,
  getAuthorMap,
  featuredArticles,
  makeDeduper,
  articleSlug,
  coverImageFor,
  coverAltFor,
} from '@/utils/content';
import { url } from '@/utils/url';
import { formatDate } from '@/utils/date';

const all = await getPublishedArticles();
const authorMap = await getAuthorMap();
const authorNames = new Map(
  [...authorMap.entries()].map(([id, a]) => [id, a.data.name]),
);
const authorName = (id: string) => authorNames.get(id) ?? 'APPI 編輯部';

const dedupe = makeDeduper();

// Hero：hero=true 優先，否則最新 featured，否則最新
const hero =
  all.find((a) => a.data.hero) ??
  all.find((a) => a.data.featured) ??
  all[0];
if (hero) dedupe.take([hero], 1);

// 精選右側：5 篇含小縮圖的清單（補滿垂直空間 + 易辨識）
const secondary = dedupe.take([...featuredArticles(all), ...all], 5);

// 最新文章：單一等高大圖網格（補滿空間）
const latest = dedupe.take(all, 12, false);

const heroCover = hero ? coverImageFor(hero) : '';
const heroHref = hero ? url(`/articles/${articleSlug(hero)}/`) : '#';
---

<BaseLayout title="首頁" path="/" ogImage="og/home.png">
  <!-- 網站介紹 Hero 區：承接從 header 移下來的中文定位 + 站台介紹 -->
  <section class="intro">
    <HeroNetwork />
    <div class="container intro-inner">
      <div class="intro-text">
        <span class="intro-eyebrow">{SITE.taglineEn}</span>
        <h1 class="intro-title">{SITE.tagline}</h1>
        <p class="intro-desc">
          聚集各領域專業作者，以新聞、評論、專欄、專題、專訪與深度分析，協助讀者理解健康、科技、財經、國際、運動與生活中的重要議題。
        </p>
        <div class="intro-cta">
          <a class="btn btn--primary" href={url('/articles/')}>探索所有文章</a>
          <a class="btn btn--ghost" href={url('/submit/')}>投稿／成為作者</a>
        </div>
      </div>

      {/* 右側：極簡媒體分類排版（Editorial Index）——取代原 SaaS 插圖 */}
      <aside class="intro-index" aria-hidden="true">
        <div class="eindex">
          <div class="eindex-head">
            <span class="eindex-brand">APPI News</span>
            <span class="eindex-kicker">Editorial Index</span>
            <span class="eindex-vol">Vol. 2026</span>
          </div>
          <ol class="eindex-list">
            <li><span class="eindex-num">01</span><span class="eindex-en">Focus</span><span class="eindex-zh">焦點</span></li>
            <li><span class="eindex-num">02</span><span class="eindex-en">International</span><span class="eindex-zh">國際</span></li>
            <li><span class="eindex-num">03</span><span class="eindex-en">Health</span><span class="eindex-zh">健康</span></li>
            <li><span class="eindex-num">04</span><span class="eindex-en">Tech</span><span class="eindex-zh">科技</span></li>
            <li><span class="eindex-num">05</span><span class="eindex-en">Finance</span><span class="eindex-zh">財經</span></li>
            <li><span class="eindex-num">06</span><span class="eindex-en">Sports</span><span class="eindex-zh">運動</span></li>
            <li><span class="eindex-num">07</span><span class="eindex-en">Lifestyle</span><span class="eindex-zh">生活</span></li>
            <li><span class="eindex-num">08</span><span class="eindex-en">Columns</span><span class="eindex-zh">專欄</span></li>
          </ol>
          <div class="eindex-foot">
            <span>Multi-author media</span>
            <span>Expert viewpoints</span>
            <span>Analysis &amp; columns</span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  {
    hero && (
      <div class="container">
        <section class="section feature-section">
          <div class="section-head">
            <h2>編輯精選</h2>
            <a class="more-link" href={url('/articles/')}>所有文章 →</a>
          </div>

          <div class="feature">
            <article class="feature-main">
              <a class="feature-media" href={heroHref} tabindex="-1" aria-hidden="true">
                <ImageWithFallback
                  src={heroCover}
                  alt={coverAltFor(hero)}
                  fallback={`og/${hero.data.category}.png`}
                  loading="eager"
                  class="feature-img"
                />
              </a>
              <div class="feature-text">
                <CategoryTag category={hero.data.category} subcategory={hero.data.subcategory} />
                <h3 class="feature-title"><a href={heroHref}>{hero.data.title}</a></h3>
                <p class="feature-excerpt">{hero.data.excerpt ?? hero.data.description}</p>
                <span class="feature-meta">
                  {authorName(hero.data.author)} · {formatDate(hero.data.publishDate)}
                </span>
              </div>
            </article>

            <div class="feature-side">
              {
                secondary.map((a) => (
                  <a class="side-item" href={url(`/articles/${articleSlug(a)}/`)}>
                    <span class="side-thumb">
                      <ImageWithFallback
                        src={coverImageFor(a)}
                        alt={coverAltFor(a)}
                        fallback={`og/${a.data.category}.png`}
                        class="side-img"
                      />
                    </span>
                    <span class="side-body">
                      <span class="side-title">{a.data.title}</span>
                      <span class="side-meta">
                        {authorName(a.data.author)} · {formatDate(a.data.publishDate)}
                      </span>
                    </span>
                  </a>
                ))
              }
            </div>
          </div>
        </section>
      </div>
    )
  }

  <div class="container">
    <section class="section home-latest">
      <div class="section-head">
        <h2>最新文章</h2>
        <a class="more-link" href={url('/articles/')}>所有文章 →</a>
      </div>
      <div class="card-grid card-grid--3">
        {
          latest.map((a) => (
            <ArticleCard
              article={a}
              variant="medium"
              showExcerpt={false}
              authorName={authorNames.get(a.data.author)}
            />
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ---------- 網站介紹 Hero 區 ---------- */
  .intro {
    position: relative;
    background:
      radial-gradient(120% 150% at 88% 0%, var(--bg-tint) 0%, transparent 58%),
      linear-gradient(180deg, var(--bg-soft) 0%, var(--white) 100%);
    border-bottom: 1px solid var(--line-2);
  }
  .intro-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1.2fr; /* 左 ~45% / 右 ~55% */
    align-items: center;
    gap: 48px;
    padding-top: 56px;
    padding-bottom: 56px;
  }
  .intro-eyebrow {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--appi-accent);
    font-weight: 600;
  }
  .intro-title {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    line-height: 1.2;
    margin: 12px 0 0;
    color: var(--ink);
  }
  .intro-desc {
    margin: 16px 0 24px;
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--ink-2);
    max-width: 54ch;
  }
  .intro-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  /* ---------- 右側：Editorial Index 排版視覺 ---------- */
  .intro-index {
    display: flex;
    justify-content: center;
  }
  .eindex {
    position: relative;
    width: 100%;
    max-width: 560px;
    padding: 26px 32px 22px;
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    /* 淡色半透明面板，讓背景節點線條若隱若現但不搶主體 */
    background: color-mix(in oklch, var(--white) 82%, transparent);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }
  /* 左上金色細邊強調，營造 issue／index 感 */
  .eindex::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, var(--appi-accent) 0%, transparent 72%);
  }
  .eindex-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--appi-accent);
    font-family: var(--font-sans);
  }
  .eindex-brand {
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: var(--text-xs);
    color: var(--appi-brand);
  }
  .eindex-kicker {
    font-size: 0.8125rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .eindex-vol {
    margin-left: auto;
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    font-weight: 600;
    color: var(--appi-accent);
  }
  .eindex-list {
    list-style: none;
    margin: 0;
    padding: 18px 0 16px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 30px;
    row-gap: 12px;
  }
  .eindex-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: baseline;
    column-gap: 10px;
    row-gap: 2px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--line-2);
  }
  .eindex-num {
    grid-row: 1;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--appi-accent);
  }
  .eindex-en {
    grid-row: 1;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.1;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--appi-brand);
  }
  .eindex-zh {
    grid-column: 2;
    grid-row: 2;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--ink-3);
  }
  .eindex-foot {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 18px;
    padding-top: 14px;
    border-top: 1px solid var(--appi-accent);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-2);
  }

  /* ---------- 編輯精選 ---------- */
  .feature {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 40px;
  }
  .feature-media {
    display: block;
    overflow: hidden;
    border-radius: var(--radius);
    aspect-ratio: 16 / 9;
    background: var(--bg-soft);
    box-shadow: var(--shadow-md);
  }
  :global(.feature-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .feature-media:hover :global(.feature-img) {
    transform: scale(1.03);
  }
  .feature-text {
    padding-top: 18px;
  }
  .feature-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    line-height: 1.3;
    margin: 12px 0;
  }
  .feature-title a {
    color: var(--ink);
    text-decoration: none;
  }
  .feature-title a:hover {
    color: var(--appi-brand);
  }
  .feature-excerpt {
    color: var(--ink-2);
    font-size: var(--text-base);
    line-height: 1.7;
    margin: 0 0 14px;
  }
  .feature-meta {
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
  }

  /* 精選右側：含小縮圖的文章清單（金色強調左線） */
  .feature-side {
    display: flex;
    flex-direction: column;
    border-left: 3px solid var(--appi-accent);
    padding-left: 24px;
  }
  .side-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 16px 0;
    text-decoration: none;
    border-bottom: 1px solid var(--line-2);
  }
  .side-item:first-child {
    padding-top: 0;
  }
  .side-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .side-thumb {
    flex: 0 0 88px;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--bg-soft);
  }
  :global(.side-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .side-item:hover :global(.side-img) {
    transform: scale(1.05);
  }
  .side-body {
    flex: 1;
    min-width: 0;
  }
  .side-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.25rem; /* 20px — 恢復至先前列表字級 */
    line-height: 1.45;
    color: var(--ink);
  }
  .side-item:hover .side-title {
    color: var(--appi-brand);
  }
  .side-meta {
    display: block;
    margin-top: 6px;
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
  }

  /* ---------- 最新文章：恢復至先前較大的卡片標題字級 ---------- */
  .home-latest :global(.acard--medium .acard-title) {
    font-size: 1.375rem; /* 22px */
  }

  @media (max-width: 900px) {
    .intro-inner {
      grid-template-columns: 1fr;
      gap: 28px;
      padding-top: 40px;
      padding-bottom: 40px;
    }
    /* 手機／平板：文字在上、分類視覺在下（依 DOM 順序，不需 order） */
    .eindex {
      max-width: 640px;
    }
    .feature {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .feature-side {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--line);
      padding-top: 8px;
    }
  }

  @media (max-width: 520px) {
    .side-thumb {
      flex-basis: 72px;
    }
    .side-title {
      font-size: 1.125rem;
    }
    /* 手機：分類視覺縮成精簡矩陣，避免首屏過長 */
    .eindex {
      padding: 20px 20px 16px;
    }
    .eindex-list {
      column-gap: 18px;
      row-gap: 10px;
    }
    .eindex-en {
      font-size: 0.95rem;
    }
    .eindex-vol {
      display: none;
    }
    .eindex-foot {
      letter-spacing: 0.1em;
    }
  }
</style>
