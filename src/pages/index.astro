---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/blocks/ArticleCard.astro';
import ImageWithFallback from '@/components/ui/ImageWithFallback.astro';
import CategoryTag from '@/components/ui/CategoryTag.astro';
import {
  getPublishedArticles,
  getAuthorMap,
  featuredArticles,
  makeDeduper,
  articleSlug,
  coverImageFor,
  coverAltFor,
} from '@/utils/content';
import { url } from '@/utils/url';
import { formatDate } from '@/utils/date';

const all = await getPublishedArticles();
const authorMap = await getAuthorMap();
const authorNames = new Map(
  [...authorMap.entries()].map(([id, a]) => [id, a.data.name]),
);

const dedupe = makeDeduper();

// Hero：hero=true 優先，否則最新 featured，否則最新
const hero =
  all.find((a) => a.data.hero) ??
  all.find((a) => a.data.featured) ??
  all[0];
if (hero) dedupe.take([hero], 1);

// Hero 右側：4 篇純文字標題清單（對齊 K 版型的 .side）
const secondary = dedupe.take([...featuredArticles(all), ...all], 4);

// 最新文章：單一等高大圖網格（對齊 K 版型，取代原多分類區塊）
const latest = dedupe.take(all, 12, false);

const heroCover = hero ? coverImageFor(hero) : '';
const heroHref = hero ? url(`/articles/${articleSlug(hero)}/`) : '#';
---

<BaseLayout title="首頁" path="/" ogImage="og/home.png">
  {
    hero && (
      <section class="hero container">
        <div class="hero-main">
          <a class="hero-media" href={heroHref} tabindex="-1" aria-hidden="true">
            <ImageWithFallback
              src={heroCover}
              alt={coverAltFor(hero)}
              fallback={`og/${hero.data.category}.png`}
              loading="eager"
              class="hero-img"
            />
          </a>
          <div class="hero-text">
            <CategoryTag category={hero.data.category} subcategory={hero.data.subcategory} />
            <h1><a href={heroHref}>{hero.data.title}</a></h1>
            <p>{hero.data.excerpt ?? hero.data.description}</p>
            <span class="hero-meta">
              {authorNames.get(hero.data.author) ?? 'APPI 編輯部'} · {formatDate(hero.data.publishDate)}
            </span>
          </div>
        </div>

        <div class="hero-side divided-list">
          {
            secondary.map((a) => (
              <a class="hs-item" href={url(`/articles/${articleSlug(a)}/`)}>
                <span class="hs-title">{a.data.title}</span>
                <span class="hs-meta">
                  {authorNames.get(a.data.author) ?? 'APPI 編輯部'} · {formatDate(a.data.publishDate)}
                </span>
              </a>
            ))
          }
        </div>
      </section>
    )
  }

  <div class="container">
    <!-- 最新文章：單一網格（K 版型） -->
    <section class="section">
      <div class="section-head">
        <h2>最新文章</h2>
        <a class="more-link" href={url('/articles/')}>所有文章 →</a>
      </div>
      <div class="card-grid card-grid--3">
        {
          latest.map((a) => (
            <ArticleCard
              article={a}
              variant="medium"
              showExcerpt={false}
              authorName={authorNames.get(a.data.author)}
            />
          ))
        }
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: 36px;
    padding-top: 36px;
    margin-bottom: 24px;
  }
  .hero-main {
    display: block;
  }
  .hero-media {
    display: block;
    overflow: hidden;
    border-radius: var(--radius);
    aspect-ratio: 16 / 9;
    background: var(--bg-soft);
  }
  :global(.hero-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .hero-media:hover :global(.hero-img) {
    transform: scale(1.03);
  }
  .hero-text {
    padding-top: 16px;
  }
  .hero-text h1 {
    font-size: var(--text-xl);
    line-height: 1.3;
    margin: 12px 0;
  }
  .hero-text h1 a {
    color: var(--ink);
    text-decoration: none;
  }
  .hero-text h1 a:hover {
    color: var(--appi-brand);
  }
  .hero-text p {
    color: var(--ink-2);
    font-size: var(--text-sm);
    line-height: 1.7;
    margin: 0 0 12px;
  }
  .hero-meta {
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
  }
  .hero-side {
    /* K 的金色強調左線；縱向每則淡分隔由 global .divided-list 控制（金竖線＋淡横線，K＋E） */
    border-left: 3px solid var(--appi-accent);
    padding-left: 28px;
  }
  /* K 版型 hero 右側：純文字標題清單（無縮圖） */
  .hs-item {
    display: block;
    text-decoration: none;
  }
  .hs-title {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: 1.45;
    color: var(--ink);
  }
  .hs-item:hover .hs-title {
    color: var(--appi-brand);
  }
  .hs-meta {
    display: block;
    margin-top: 6px;
    font-size: var(--text-xs);
    color: var(--ink-3);
    font-family: var(--font-sans);
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .hero-side {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--line);
      padding-top: 24px;
    }
    .hero-text h1 {
      font-size: var(--text-xl);
    }
  }
</style>
