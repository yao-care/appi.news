---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/ui/Breadcrumbs.astro';
import { url } from '@/utils/url';

const formats = [
  '新聞稿刊登', '專題合作', '品牌專欄', '企業專訪',
  '活動報導', '產業白皮書', '社群圖卡', '內容策略顧問',
];
---
<BaseLayout
  title="新聞稿與商業合作"
  description="APPI 提供新聞稿刊登、品牌專欄、專題合作等商業合作形式，所有商業內容均依規範揭露。"
  path="/sponsored/"
>
  <div class="container" style="padding-top:28px;">
    <Breadcrumbs items={[{ name: '新聞稿與商業合作' }]} />
    <header class="sponsored-head">
      <h1>新聞稿與商業合作</h1>
      <p>
        APPI 與品牌、企業與機構合作，將專業資訊以符合媒體規格的方式呈現，讓訊息精準觸及關注相關領域的讀者。
        我們相信好的商業內容同樣需要可信度，因此所有合作內容都會依揭露規範清楚標示，並維持本站一貫的內容品質。
      </p>
    </header>

    <section class="section">
      <div class="section-head"><h2>合作形式</h2></div>
      <p class="section-intro">
        從單篇新聞稿到長期的品牌專欄與內容顧問，我們提供多種合作形式，可依你的目標與預算彈性搭配。
      </p>
      <div class="format-grid">
        {formats.map((f) => <div class="format-card">{f}</div>)}
      </div>
    </section>

    <section class="section">
      <div class="section-head"><h2>合作流程</h2></div>
      <ol class="flow-list">
        <li><strong>需求洽談</strong>：來信說明合作目標、希望傳達的訊息、形式與時程。</li>
        <li><strong>提案與報價</strong>：我們依你的需求建議合適的合作形式與內容架構，並提供報價。</li>
        <li><strong>內容製作</strong>：由你提供素材或由 APPI 協助產製，過程中確認重點與用語。</li>
        <li><strong>查核與揭露</strong>：內容經編輯查核並加註揭露標示，確保符合本站規範。</li>
        <li><strong>刊登與成效</strong>：文章發布於 APPI News，並可視合作規模提供基本的成效回報。</li>
      </ol>
    </section>

    <section class="section disclosure-rules">
      <div class="section-head"><h2>商業內容揭露原則</h2></div>
      <p class="section-intro">
        誠實揭露是 APPI 與讀者之間信任的基礎。為維護內容的公信力，所有商業合作均遵循下列原則：
      </p>
      <ul>
        <li>所有商業合作內容必須標示「合作」「贊助」「新聞稿」或「品牌專欄」，於顯著位置揭露。</li>
        <li>不得偽裝成中立新聞，也不得以編輯部名義發布商業內容。</li>
        <li>醫療、保健食品、財經、法律相關內容需遵守更嚴格的規範，不得宣稱療效或保證收益。</li>
        <li>編輯對事實正確性的判斷不受商業關係影響，本站保留對不符規範內容的調整與拒登權利。</li>
      </ul>
      <p class="rules-foot">
        更完整的內容準則請參閱<a href={url('/editorial-policy/')}>編輯方針</a>。
      </p>
    </section>

    <section class="sponsored-cta">
      <h2>洽談合作</h2>
      <p>請來信說明你的需求與目標，我們會在數個工作日內回覆，並提供合適的合作建議。</p>
      <a class="btn btn--primary" href={url('/contact/')}>聯絡 APPI 商業合作</a>
    </section>
  </div>
</BaseLayout>

<style>
  .sponsored-head {
    margin: 18px 0 36px;
  }
  .sponsored-head h1 {
    font-size: var(--text-2xl);
    margin: 0 0 10px;
  }
  .sponsored-head p {
    color: var(--ink-2);
    max-width: 680px;
    line-height: 1.7;
    margin: 0;
  }
  .section-intro {
    color: var(--ink-2);
    max-width: 720px;
    line-height: 1.8;
    margin: 0 0 20px;
  }
  .flow-list {
    line-height: 1.9;
    color: var(--ink-2);
    max-width: 720px;
    padding-left: 1.2em;
  }
  .flow-list li {
    margin-bottom: 6px;
  }
  .rules-foot {
    color: var(--ink-2);
    margin-top: 16px;
  }
  .format-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .format-card {
    background: var(--bg-soft);
    border-radius: var(--radius);
    padding: 24px 18px;
    text-align: center;
    font-weight: 600;
    color: var(--ink-2);
  }
  .disclosure-rules ul {
    line-height: 1.9;
    color: var(--ink-2);
    max-width: 720px;
  }
  .sponsored-cta {
    text-align: center;
    background: var(--bg-tint);
    border-radius: var(--radius);
    padding: 48px 24px;
    margin-block: 56px;
  }
  .sponsored-cta h2 {
    margin: 0 0 8px;
  }
  .sponsored-cta p {
    color: var(--ink-2);
    margin: 0 0 20px;
  }

  @media (max-width: 860px) {
    .format-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
